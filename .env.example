# --- Beacon configuration ---

# Public base URL where this service is reachable (goes into the agent card + skill_md_url).
# For local dev leave as-is; for the demo set to your ngrok/fly/droplet URL.
PUBLIC_URL=http://localhost:6000

# Chain adapter: "live" reads Base Sepolia; "mock" runs fully offline (tests + demo safety).
CHAIN_MODE=live

# Base Sepolia (ERC-8004). Free, no API key.
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_SEPOLIA_RPC_FALLBACK=https://base-sepolia-rpc.publicnode.com
CHAIN_ID=84532
IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713

# A real Base Sepolia ERC-8004 token id with a rich AgentCard + populated reputation.
DEMO_TOKEN_ID=17

# NANDA city registry (live droplet). Beacon reads this FIRST.
NANDA_REGISTRY_URL=http://67.205.176.71

# Optional: enables an LLM fallback for fuzzy intent parsing. Leave blank for deterministic-only.
OPENAI_API_KEY=
